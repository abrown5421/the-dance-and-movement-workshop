# Database
MONGO_URI=

# Server Config
PORT=3000
HOST=localhost
NODE_ENV=development

# Auth
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=3d

# Origins
FRONTEND_ORIGIN=
CMS_ORIGIN=
VITE_API_ORIGIN=
CORS_ORIGINS=

# Render deploy hook for the engagement app.
# Obtain from Render dashboard → engagement service → Settings → Deploy Hook.
# Leave unset in local dev — page creation will scaffold the file only.
RENDER_DEPLOY_HOOK_URL=

